PORT=6001

# Supabase pooler (runtime queries)
DATABASE_URL=postgres://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=false

# Direct connection (migrations only)
DIRECT_URL=postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Exact frontend URL(s) — comma-separated if www + non-www
CLIENT_ORIGIN=https://bdpoly.aftonix.com

# Redis — active game state hot store + multi-node pub/sub.
# With docker-compose the bundled service resolves as redis://redis:6379.
# Leave unset only for local dev without Redis (in-memory fallback).
REDIS_URL=redis://redis:6379
